# 复制为 .env 并填入你的 key。只需要填你打算用的那个 provider。

# ---- Anthropic (Claude) ----
ANTHROPIC_API_KEY=sk-ant-...

# ---- OpenAI (或任意 OpenAI 兼容端点) ----
OPENAI_API_KEY=sk-...
# 第三方/本地兼容端点可改这个，例如 http://localhost:11434/v1
# OPENAI_BASE_URL=https://api.openai.com/v1

# ---- 默认选择 ----
# provider: anthropic 或 openai
STELLAR_PROVIDER=anthropic
# 模型名（不填则用 provider 的默认）
# STELLAR_MODEL=claude-opus-4-8
